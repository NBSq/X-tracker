# Required only for live mode
X_BEARER_TOKEN=
OPENAI_API_KEY=

# Optional in both modes. Set both values to enable Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App settings
DATABASE_PATH=x_narrative_tracker.sqlite3
OPENAI_MODEL=gpt-4o-mini
FETCH_INTERVAL_SECONDS=900
HYPE_ALERT_THRESHOLD=25
POSTS_PER_ACCOUNT=10
RSS_ARTICLES_PER_FEED=10
